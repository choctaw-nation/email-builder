{
	"name": "cno-email-builder-theme",
	"version": "1.1.2",
	"engines": {
		"node": ">= 24"
	},
	"description": "Custom WP theme",
	"prettier": "@wordpress/prettier-config",
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"scripts": {
		"build": "wp-scripts build --blocks-manifest --webpack-copy-php --source-path=wp-content/themes/cno-email-builder/src/ --output-path=wp-content/themes/cno-email-builder/dist/",
		"check-engines": "wp-scripts check-engines",
		"lint:css": "npx stylelint '**/*.scss' '**/*.css' --fix",
		"lint:js": "npx eslint --fix",
		"packages-update": "wp-scripts packages-update",
		"start": "wp-scripts start --blocks-manifest --webpack-copy-php --source-path=wp-content/themes/cno-email-builder/src/ --output-path=wp-content/themes/cno-email-builder/dist/"
	},
	"author": "Choctaw Nation of Oklahoma",
	"license": "GPL-3.0-or-later",
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/eslintrc": "^3.3.5",
		"@wordpress/blob": "^4.42.0",
		"@wordpress/block-editor": "^15.15.0",
		"@wordpress/blocks": "^15.15.0",
		"@wordpress/components": "^32.4.0",
		"@wordpress/data": "^10.42.0",
		"@wordpress/dom-ready": "^4.42.0",
		"@wordpress/editor": "^14.42.0",
		"@wordpress/element": "^6.42.0",
		"@wordpress/eslint-plugin": "^24.4.0",
		"@wordpress/hooks": "^4.42.0",
		"@wordpress/icons": "^12.0.0",
		"@wordpress/scripts": "^31.7.0",
		"bootstrap": "^5.3.8",
		"eslint": "^9",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-react-hooks": "^7.0.1",
		"globals": "^17.4.0",
		"react": "^18",
		"stylelint": "^17.6.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-scss": "^7.0.0",
		"webpack-remove-empty-scripts": "^1.1.1"
	}
}
